APP_ENV=prod
LOG_LEVEL=INFO

# Guard rail: keep this disabled in production. Setting to 1 allows test scopes
# and test/sample config rows to run in prod (break-glass only).
ALLOW_TEST_DATA_IN_PROD=0

# Prevent Python from writing .pyc / __pycache__ files for this shell/session.
# PowerShell alternative (recommended): $env:PYTHONDONTWRITEBYTECODE = "1"
PYTHONDONTWRITEBYTECODE=1

# =========================
# SQL Server — per-environment (dev and prod connect to different servers)
# =========================
# SQL auth mode options:
#   - passwordless integrated: windows / sspi / trusted_connection / ad_integrated / active_directory_integrated
#   - passwordless token-based: managed_identity
#   - credential-based: sql_password / ad_password / active_directory_password
#
# Dev SQL Server (e.g. local Windows instance)
SQL_SERVER_HOST_DEV=.
SQL_SERVER_PORT_DEV=1433
SQL_AUTH_MODE_DEV=sspi
SQL_ODBC_DRIVER_DEV=ODBC Driver 18 for SQL Server
SQL_TRUST_SERVER_CERTIFICATE_DEV=1

# Prod SQL Server (e.g. Azure SQL or remote Windows SQL Server)
SQL_SERVER_HOST_PROD=your-prod-sql-server.database.windows.net
SQL_SERVER_PORT_PROD=1433
SQL_AUTH_MODE_PROD=sspi
SQL_ODBC_DRIVER_PROD=ODBC Driver 18 for SQL Server
SQL_TRUST_SERVER_CERTIFICATE_PROD=1
# Alternative prod auth (explicit AD/SQL creds sourced from Key Vault):
# SQL_AUTH_MODE_PROD=ad_password

# Optional shared fallback — used only when no env-specific value is set.
# Avoid setting these in normal usage; prefer the per-env vars above.
# SQL_SERVER_HOST=.
# SQL_SERVER_PORT=1433
# SQL_AUTH_MODE=sspi
# SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
# SQL_TRUST_SERVER_CERTIFICATE=1

# ── Per-environment database names ───────────────────────────────────────────
# Database names are resolved exclusively from Azure Key Vault at runtime.
# No env-var fallback is supported — the application will raise at startup if
# any of the three secrets cannot be fetched.
#
# Required secrets per environment (seeded via sharepoint_setup/keyvault_setup.py):
#   kv-sp-ingest-dev  → dm-sql-dev-aud-database, dm-sql-dev-stg-database, dm-sql-dev-int-database
#   kv-sp-ingest-prod → dm-sql-prod-aud-database, dm-sql-prod-stg-database, dm-sql-prod-int-database
#
# To override the secret names (non-standard vaults only):
# KEYVAULT_SQL_AUD_DATABASE_SECRET_NAME_DEV=dm-sql-dev-aud-database
# KEYVAULT_SQL_STG_DATABASE_SECRET_NAME_DEV=dm-sql-dev-stg-database
# KEYVAULT_SQL_INT_DATABASE_SECRET_NAME_DEV=dm-sql-dev-int-database
# KEYVAULT_SQL_AUD_DATABASE_SECRET_NAME_PROD=dm-sql-prod-aud-database
# KEYVAULT_SQL_STG_DATABASE_SECRET_NAME_PROD=dm-sql-prod-stg-database
# KEYVAULT_SQL_INT_DATABASE_SECRET_NAME_PROD=dm-sql-prod-int-database

# =========================
# SharePoint URLs
# =========================
# SharePoint site URL is resolved at runtime from Azure Key Vault
# (secret: dm-sharepoint-{env}-site-url).  Set the env vars below only as an
# emergency local-dev override when Key Vault is unavailable.
# SHAREPOINT_SITE_URL_DEV=https://mycompany715.sharepoint.com/sites/data_ingest_dev
# SHAREPOINT_SITE_URL_PROD=https://mycompany715.sharepoint.com/sites/data_ingestion_prod
SHAREPOINT_ADMIN_URL_PROD=https://mycompany715-admin.sharepoint.com

# Folder path used by sharepoint_setup/sharepoint_auth_test.py to verify
# read access after authentication.  Use a document library root or any
# subfolder that the SPN has permission to access.
# "Shared Documents" (the default document library) is sufficient for a
# basic connectivity check.
SHAREPOINT_TEST_FOLDER_DEV=Shared Documents
SHAREPOINT_TEST_FOLDER_PROD=Shared Documents

# =========================
# Azure / Key Vault
# =========================
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP_DEV=rg-sp-ingest-dev
AZURE_RESOURCE_GROUP_PROD=rg-sp-ingest-prod
# Optional shared fallback (used only when env-specific value is not set)
# AZURE_RESOURCE_GROUP=rg-sp-ingest
KEY_VAULT_NAME_DEV=kv-sp-ingest-dev
KEY_VAULT_URL_DEV=https://kv-sp-ingest-dev.vault.azure.net/
KEY_VAULT_NAME_PROD=kv-sp-ingest-prod
KEY_VAULT_URL_PROD=https://kv-sp-ingest-prod.vault.azure.net/

# Optional shared fallback (used only when env-specific values are not set)
# KEY_VAULT_NAME=
# KEY_VAULT_URL=

# ── Key Vault secret names ────────────────────────────────────────────────────
#
# kv-sp-ingest-dev secrets:
#   dm-sharepoint-dev-client-id
#   dm-sharepoint-dev-client-secret
#   dm-sharepoint-dev-tenant-id
#   dm-sharepoint-dev-site-url
#   dm-sql-dev-server
#   dm-sql-dev-int-database
#   dm-sql-dev-stg-database
#   dm-sql-dev-aud-database
#
# kv-sp-ingest-prod secrets:
#   dm-sharepoint-prod-client-id
#   dm-sharepoint-prod-client-secret
#   dm-sharepoint-prod-tenant-id
#   dm-sharepoint-prod-site-url
#   dm-sql-prod-server
#   dm-sql-prod-int-database
#   dm-sql-prod-stg-database
#   dm-sql-prod-aud-database
#
# The default secret names are auto-derived from the env name (dev|prod), so
# the env-specific overrides below are usually not required.  Set them only if
# your vault uses a non-standard naming convention.

# SharePoint secret name overrides (env-specific)
# KEYVAULT_CLIENT_ID_SECRET_NAME_DEV=dm-sharepoint-dev-client-id
# KEYVAULT_CLIENT_SECRET_SECRET_NAME_DEV=dm-sharepoint-dev-client-secret
# KEYVAULT_TENANT_ID_SECRET_NAME_DEV=dm-sharepoint-dev-tenant-id
# KEYVAULT_SITE_URL_SECRET_NAME_DEV=dm-sharepoint-dev-site-url
# KEYVAULT_CLIENT_ID_SECRET_NAME_PROD=dm-sharepoint-prod-client-id
# KEYVAULT_CLIENT_SECRET_SECRET_NAME_PROD=dm-sharepoint-prod-client-secret
# KEYVAULT_TENANT_ID_SECRET_NAME_PROD=dm-sharepoint-prod-tenant-id
# KEYVAULT_SITE_URL_SECRET_NAME_PROD=dm-sharepoint-prod-site-url

# SQL server / database secret name overrides (env-specific)
# KEYVAULT_SQL_SERVER_SECRET_NAME_DEV=dm-sql-dev-server
# KEYVAULT_SQL_INT_DATABASE_SECRET_NAME_DEV=dm-sql-dev-int-database
# KEYVAULT_SQL_STG_DATABASE_SECRET_NAME_DEV=dm-sql-dev-stg-database
# KEYVAULT_SQL_AUD_DATABASE_SECRET_NAME_DEV=dm-sql-dev-aud-database
# KEYVAULT_SQL_SERVER_SECRET_NAME_PROD=dm-sql-prod-server
# KEYVAULT_SQL_INT_DATABASE_SECRET_NAME_PROD=dm-sql-prod-int-database
# KEYVAULT_SQL_STG_DATABASE_SECRET_NAME_PROD=dm-sql-prod-stg-database
# KEYVAULT_SQL_AUD_DATABASE_SECRET_NAME_PROD=dm-sql-prod-aud-database

# SQL credential secret names (required only for credential-based auth modes)
KEYVAULT_SQL_USERNAME_SECRET_NAME_DEV=dm-sql-dev-username
KEYVAULT_SQL_PASSWORD_SECRET_NAME_DEV=dm-sql-dev-password
KEYVAULT_SQL_USERNAME_SECRET_NAME_PROD=dm-sql-prod-username
KEYVAULT_SQL_PASSWORD_SECRET_NAME_PROD=dm-sql-prod-password

# Optional fallback secret values (only for local dev troubleshooting)
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID_DEV=
# SHAREPOINT_CLIENT_SECRET_DEV=
# SHAREPOINT_TENANT_ID_DEV=
# SHAREPOINT_CLIENT_ID_PROD=
# SHAREPOINT_CLIENT_SECRET_PROD=
# SHAREPOINT_TENANT_ID_PROD=

# Optional SQL credential fallback values (avoid in normal usage; prefer AKV)
# Not needed when SQL_AUTH_MODE_* is passwordless (e.g., windows/sspi/ad_integrated)
# SQL_SERVER_USERNAME=
# SQL_SERVER_PASSWORD=
# SQL_SERVER_USERNAME_DEV=
# SQL_SERVER_PASSWORD_DEV=
# SQL_SERVER_USERNAME_PROD=
# SQL_SERVER_PASSWORD_PROD=

# =========================
# Ingestion behaviour
# =========================
DEFAULT_LOAD_STRATEGY=TRUNCATE
DEFAULT_FILE_PATTERN=*
NULL_ALERT_THRESHOLD=0.90
ENABLE_CHUNKED_CSV=0
ENABLE_CHUNKED_PARQUET=1
INGEST_CHUNK_SIZE_ROWS=5000

# =========================
# Email notifications (SMTP)
# =========================
EMAIL_NOTIFICATIONS_ENABLED=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=1
EMAIL_FROM_ADDRESS=sharepoint-ingest@company715.onmicrosoft.com

# =========================
# Layer 5 test (SQL Database Mail)
# =========================
# Default/fallback profile + recipients
DBMAIL_PROFILE_NAME=
DBMAIL_TEST_TO=
# Optional per-environment overrides
DBMAIL_PROFILE_NAME_DEV=
DBMAIL_PROFILE_NAME_PROD=
DBMAIL_TEST_TO_DEV=
DBMAIL_TEST_TO_PROD=
# Optional subject prefix used by sharepoint_setup/dbmail_send_test.py
DBMAIL_TEST_SUBJECT_PREFIX=sharepoint-ingest

# Optional local smtp4dev notes for dev SQL Database Mail profile wiring
# DBMAIL_PROFILE_NAME_DEV=Dev Local SMTP
# DBMAIL_TEST_TO_DEV=dev-test@local.invalid
# LOCAL_SMTP4DEV_HOST=localhost
# LOCAL_SMTP4DEV_PORT=2525
# LOCAL_SMTP4DEV_WEB_UI=http://localhost:5000
