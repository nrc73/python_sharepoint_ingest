APP_ENV=prod
LOG_LEVEL=INFO

# Prevent Python from writing .pyc / __pycache__ files for this shell/session.
# PowerShell alternative (recommended): $env:PYTHONDONTWRITEBYTECODE = "1"
PYTHONDONTWRITEBYTECODE=1

# =========================
# SQL Server
# =========================
# Optional default host fallback
SQL_SERVER_HOST=localhost
# Per-environment SQL hosts
SQL_SERVER_HOST_DEV=localhost
SQL_SERVER_HOST_PROD=your-prod-sql-server.database.windows.net
SQL_SERVER_PORT=1433
# SQL auth mode (per environment): sql_password | ad_password | ad_integrated
SQL_AUTH_MODE_DEV=sql_password
SQL_AUTH_MODE_PROD=ad_password
SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
SQL_TRUST_SERVER_CERTIFICATE=1

# Per-environment database names
SQL_DATABASE_DEV=ingest_dev
SQL_DATABASE_PROD=ingest_prod

# =========================
# SharePoint URLs
# =========================
SHAREPOINT_SITE_URL_DEV=https://mycompany715.sharepoint.com/sites/data_ingest_dev
SHAREPOINT_SITE_URL_TEST=https://mycompany715.sharepoint.com/sites/data_ingestion_test
SHAREPOINT_SITE_URL_PROD=https://mycompany715.sharepoint.com/sites/data_ingestion_prod
SHAREPOINT_ADMIN_URL_PROD=https://mycompany715-admin.sharepoint.com

# =========================
# Azure / Key Vault
# =========================
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=resource_ingest
KEY_VAULT_NAME_DEV=kv-sp-ingest-dev
KEY_VAULT_URL_DEV=https://kv-sp-ingest-dev.vault.azure.net/
KEY_VAULT_NAME_PROD=kv-sp-ingest-prod
KEY_VAULT_URL_PROD=https://kv-sp-ingest-prod.vault.azure.net/

# Optional shared fallback (used only when env-specific values are not set)
# KEY_VAULT_NAME=
# KEY_VAULT_URL=

# Secret names in Key Vault
KEYVAULT_CLIENT_ID_SECRET_NAME=dm-sharepoint-client-id
KEYVAULT_CLIENT_SECRET_SECRET_NAME=dm-sharepoint-client-secret
KEYVAULT_TENANT_ID_SECRET_NAME=dm-sharepoint-tenant-id

# Optional per-environment SharePoint secret name overrides
# KEYVAULT_CLIENT_ID_SECRET_NAME_DEV=dm-sharepoint-client-id-dev
# KEYVAULT_CLIENT_SECRET_SECRET_NAME_DEV=dm-sharepoint-client-secret-dev
# KEYVAULT_TENANT_ID_SECRET_NAME_DEV=dm-sharepoint-tenant-id-dev
# KEYVAULT_CLIENT_ID_SECRET_NAME_PROD=dm-sharepoint-client-id-prod
# KEYVAULT_CLIENT_SECRET_SECRET_NAME_PROD=dm-sharepoint-client-secret-prod
# KEYVAULT_TENANT_ID_SECRET_NAME_PROD=dm-sharepoint-tenant-id-prod

# SQL credential secret names (keep configured for both envs, even when not always used)
KEYVAULT_SQL_USERNAME_SECRET_NAME_DEV=dm-sql-dev-username
KEYVAULT_SQL_PASSWORD_SECRET_NAME_DEV=dm-sql-dev-password
KEYVAULT_SQL_USERNAME_SECRET_NAME_PROD=dm-sql-prod-username
KEYVAULT_SQL_PASSWORD_SECRET_NAME_PROD=dm-sql-prod-password

# Optional fallback secret values (only for local dev troubleshooting)
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID_DEV=
# SHAREPOINT_CLIENT_SECRET_DEV=
# SHAREPOINT_TENANT_ID_DEV=
# SHAREPOINT_CLIENT_ID_PROD=
# SHAREPOINT_CLIENT_SECRET_PROD=
# SHAREPOINT_TENANT_ID_PROD=

# Optional SQL credential fallback values (avoid in normal usage; prefer AKV)
# SQL_SERVER_USERNAME=
# SQL_SERVER_PASSWORD=
# SQL_SERVER_USERNAME_DEV=
# SQL_SERVER_PASSWORD_DEV=
# SQL_SERVER_USERNAME_PROD=
# SQL_SERVER_PASSWORD_PROD=

# =========================
# Ingestion behaviour
# =========================
DEFAULT_LOAD_STRATEGY=truncate_reload
DEFAULT_FILE_PATTERN=*
NULL_ALERT_THRESHOLD=0.90
ENABLE_CHUNKED_CSV=0
ENABLE_CHUNKED_PARQUET=1
INGEST_CHUNK_SIZE_ROWS=5000

# =========================
# Email notifications (SMTP)
# =========================
EMAIL_NOTIFICATIONS_ENABLED=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=1
EMAIL_FROM_ADDRESS=sharepoint-ingest@company715.onmicrosoft.com

# =========================
# Layer 5 test (SQL Database Mail)
# =========================
# Default/fallback profile + recipients
DBMAIL_PROFILE_NAME=
DBMAIL_TEST_TO=
# Optional per-environment overrides
DBMAIL_PROFILE_NAME_DEV=
DBMAIL_PROFILE_NAME_PROD=
DBMAIL_TEST_TO_DEV=
DBMAIL_TEST_TO_PROD=
# Optional subject prefix used by sharepoint_setup/dbmail_send_test.py
DBMAIL_TEST_SUBJECT_PREFIX=sharepoint-ingest

# Optional local smtp4dev notes for dev SQL Database Mail profile wiring
# DBMAIL_PROFILE_NAME_DEV=Dev Local SMTP
# DBMAIL_TEST_TO_DEV=dev-test@local.invalid
# LOCAL_SMTP4DEV_HOST_FOR_DOCKER_SQL=host.docker.internal
# LOCAL_SMTP4DEV_PORT=2525
# LOCAL_SMTP4DEV_WEB_UI=http://localhost:5000
